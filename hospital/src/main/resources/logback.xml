<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Properties -->
    <property name="LOG_FILE" value="hospital.log"/>
    <property name="LOG_PATTERN" value="[%d{HH:mm:ss}] %msg%n"/>
    <property name="LOG_DIR" value="/app"/>
    <property name="CHARSET" value="UTF-8"/>
    
    <!-- FILE Appender with Rolling Policy -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${LOG_FILE}</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>${CHARSET}</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>5</maxHistory>
            <totalSizeCap>50MB</totalSizeCap>
        </rollingPolicy>
    </appender>
    
    <!-- CONSOLE Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>${CHARSET}</charset>
        </encoder>
    </appender>
    
    <!-- Silence Spring Framework -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.boot" level="WARN"/>
    
    <!-- Silence Hibernate -->
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.hibernate.orm" level="WARN"/>
    
    <!-- Silence Database Drivers -->
    <logger name="com.zaxxer.hikari" level="WARN"/>
    
    <!-- Silence Tomcat/Catalina -->
    <logger name="org.apache.catalina" level="WARN"/>
    <logger name="org.apache.coyote" level="WARN"/>
    
    <!-- Application Loggers -->
    <logger name="com.gruposiete.hospital" level="INFO"/>
    
    <!-- Root Logger -->
    <root level="WARN">
        <appender-ref ref="FILE"/>
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
